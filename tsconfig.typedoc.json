{
  "include": [
    "./webpack/lib/**/*",
    "./webpack/declarations/**/*",
    "./webpack/types.d.ts"
  ],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "webpack": ["./node_modules/webpack"]
    }
  }
}
